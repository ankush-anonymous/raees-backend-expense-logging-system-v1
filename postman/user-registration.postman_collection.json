{
  "info": {
    "_postman_id": "a1b2c3d4-raees-reg",
    "name": "Raees API — User registration",
    "description": "Register with name/email (OTP emailed), then verify OTP for JWT tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "testEmail", "value": "test.user@example.com" },
    { "key": "testName", "value": "Test User" },
    { "key": "testOtp", "value": "123456" }
  ],
  "item": [
    {
      "name": "Auth — Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{testName}}\",\n  \"email\": \"{{testEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register",
        "description": "Creates/updates user and emails a 6-digit OTP. Uses collection variables."
      },
      "response": []
    },
    {
      "name": "Auth — Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{testOtp}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/verify-otp",
        "description": "Paste the OTP from your email into the `testOtp` collection variable, or edit the JSON body directly."
      },
      "response": []
    }
  ]
}
