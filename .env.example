PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/raees-expense-log

# Auth (JWT — use long random strings in production)
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional: separate secret for OTP HMAC (defaults to JWT_SECRET if unset)
# OTP_SECRET=

# Registration OTP validity (minutes)
OTP_EXPIRES_MINUTES=10

# Nodemailer (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

